# ngrok configuration for local development tunneling
# To use ngrok:
# 1. Install ngrok globally: npm install -g ngrok
# 2. Get your auth token from https://dashboard.ngrok.com/get-started/your-authtoken
# 3. Copy this file to ngrok.yml and replace YOUR_NGROK_AUTH_TOKEN_HERE
# 4. Run: ngrok start --config ngrok.yml krypta-dev

version: 3

agent:
  authtoken: YOUR_NGROK_AUTH_TOKEN_HERE

tunnels:
  krypta-dev:
    proto: http
    addr: 3000
