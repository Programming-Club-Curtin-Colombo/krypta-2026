# Site URL - used for canonical links, sitemap, and OG metadata
NEXT_PUBLIC_SITE_URL=https://krypta2026.vercel.app

# Future: email subscription API endpoint
# NEXT_PUBLIC_NOTIFY_API_URL=https://your-api.example.com/notify

# Admin Panel - PEM file hash for authentication
# Generate this by running: node -e "const crypto = require('crypto'); const fs = require('fs'); const pem = fs.readFileSync('admin-key.pem', 'utf8'); const normalized = pem.replace(/\r\n/g, '\n').replace(/\s+/g, ' ').trim(); const hash = crypto.createHash('sha256').update(normalized).digest('hex'); console.log(hash);"
ADMIN_PEM_HASH=your_generated_hash_here

# Performance Optimization - Disable WebGLFlowmap by default to save GPU/RAM resources
# Set to "true" to enable the cursor effect (not recommended for production)
NEXT_PUBLIC_ENABLE_WEBGL=false
