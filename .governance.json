{
  "audit": {
    "sinks": {
      "discord": true,
      "repo": true,
      "webhook": false
    }
  },
  "emailValidation": {
    "enabled": true,
    "allowedEmailDomains": [
      "student.curtin.edu.au"
    ]
  },
  "roles": {
    "maintainers": [
      "aaron-fredrick"
    ],
    "external": {
      "whitelistUsers": [],
      "requireApproval": true,
      "requireDomainCheck": true
    }
  },
  "debug": {
    "dryRun": false
  },
  "requiredStages": {
    "lint": true,
    "test": true,
    "security": true,
    "build": true,
    "static": true
  },
  "structure": {
    "directories": [
      ".github/workflows",
      ".github/ISSUE_TEMPLATE"
    ],
    "anyOfDirectories": [
      [
        "tests",
        "src/tests"
      ]
    ],
    "files": [
      ".gitignore",
      ".governance.json",
      "README.md",
      "docs/ARCHITECTURE.md",
      ".github/ISSUE_TEMPLATE/config.yml"
    ],
    "anyOfFiles": [
      [
        ".github/ISSUE_TEMPLATE/bug_report.yml",
        ".github/ISSUE_TEMPLATE/bug_report.md"
      ],
      [
        ".github/ISSUE_TEMPLATE/feature_request.yml",
        ".github/ISSUE_TEMPLATE/feature_request.md"
      ]
    ],
    "publicFiles": [
      "docs/CONTRIBUTING.md",
      "docs/CODE_OF_CONDUCT.md"
    ],
    "publicAnyOfFiles": [
      [
        "SECURITY.md",
        ".github/SECURITY.md"
      ]
    ]
  }
}