{
  "name": "krypta-2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "dev:low-mem": "cross-env NODE_OPTIONS=\"--max-old-space-size=2048\" next dev --turbopack -p 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose --reporter=junit --outputFile.junit=junit.xml",
    "test:coverage": "vitest run --coverage",
    "tunnel": "wait-on http://localhost:3000 && ngrok start --config ngrok.yml krypta-dev",
    "dev:tunnel": "concurrently \"npm run dev\" \"npm run tunnel\"",
    "dev:tunnel:low-mem": "concurrently \"npm run dev:low-mem\" \"npm run tunnel\""
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "es-abstract": "^1.24.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "ngrok": "^5.0.0-beta.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
